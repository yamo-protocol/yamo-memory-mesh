# LLM Provider Configuration for Reflection Generation
# Required for LLM-powered reflection generation (optional feature)

# Provider: 'openai', 'anthropic', or 'ollama'
LLM_PROVIDER=openai

# API Key for OpenAI or Anthropic (not required for Ollama)
LLM_API_KEY=sk-your-api-key-here

# Model name (provider-specific)
LLM_MODEL=gpt-4o-mini

# Optional: Custom API base URL (for proxies, Azure OpenAI, local servers)
# LLM_BASE_URL=https://api.openai.com/v1

# YAMO Protocol Configuration

# Enable YAMO block emission for audit trail (default: true)
ENABLE_YAMO=true

# Enable verbose YAMO logging (default: false)
YAMO_DEBUG=false

# LanceDB Vector Database Configuration

# Path to LanceDB storage
LANCEDB_URI=./runtime/data/lancedb

# Memory table name
LANCEDB_MEMORY_TABLE=memory_entries

# YAMO audit log table name
# LANCEDB_YAMO_TABLE=yamo_log

# Embedding Model Configuration

# Embedding type: 'local', 'openai', 'cohere', or 'ollama'
EMBEDDING_MODEL_TYPE=local

# Model name for embeddings
EMBEDDING_MODEL_NAME=Xenova/all-MiniLM-L6-v2

# Embedding vector dimension
EMBEDDING_DIMENSION=384

# -------------------------------------------------------------------------
# Quick Setup Examples
# -------------------------------------------------------------------------

# --- OpenAI (Recommended for Production) ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini

# --- Anthropic Claude ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-3-5-haiku-20241022

# --- Ollama (Local, Free) ---
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# -------------------------------------------------------------------------
# See docs/LLM_SETUP.md for complete setup guide
# -------------------------------------------------------------------------
